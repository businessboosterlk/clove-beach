<!-- start Simple Custom CSS and JS -->
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Target by link text
    const menuLinks = document.querySelectorAll('.book-btn nav ul li:last-child a');

    menuLinks.forEach(function(link) {
        link.addEventListener('click', function() {
            gtag('event', 'booking_click', {
                'menu_item': this.textContent.trim(),
                'link_url': this.href
            });
        });
    });
});

document.addEventListener('DOMContentLoaded', function() {
    const bookingButtons = document.querySelectorAll('table#stylized .btn');

    bookingButtons.forEach(function(btn) {
        btn.addEventListener('click', function(e) {
            e.preventDefault();

            var form = this.closest('form');

            gtag('event', 'booking_form_submit', {
                'button_text': this.textContent.trim(),
                'page_url': window.location.href,
                'event_callback': function() {
                    if (form) {
                        form.submit();
                    } else {
                        window.location.href = btn.href;
                    }
                }
            });

            // Safety timeout in case gtag callback fails
            setTimeout(function() {
                if (form) {
                    form.submit();
                }
            }, 1000);
        });
    });
});</script>
<!-- end Simple Custom CSS and JS -->
</body>
</html> 


